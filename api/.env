# ── AI Provider ──────────────────────────────────────────────────────────────
# Which model provider to use: anthropic | openai
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=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
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Only needed when AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Server ────────────────────────────────────────────────────────────────────
# "*" allows all origins (works with Lovable previews and local dev).
# Restrict to specific origins in production: http://localhost:8080,https://yourapp.com
ALLOWED_ORIGINS=*

# Temporary directory for uploaded files
UPLOAD_DIR=/tmp/tender-maestro-uploads
