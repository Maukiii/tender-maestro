# ── AI Provider ──────────────────────────────────────────────────────────────
# Which model provider to use: anthropic | openai
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Only needed when AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Server ────────────────────────────────────────────────────────────────────
# Leave as "*" (default) to allow all origins — works with Lovable previews and local dev.
# Restrict to specific origins in production, e.g.: http://localhost:8080,https://yourapp.com
# Note: credentials (cookies) are disabled when ALLOWED_ORIGINS=*
ALLOWED_ORIGINS=*

# Temporary directory for uploaded files
UPLOAD_DIR=/tmp/tender-maestro-uploads
